{
  "name": "yumatrix-studio",
  "version": "2.0.0",
  "type": "module",
  "description": "YuMatrix Studio — 多平台内容矩阵管理工作室",
  "main": "./out/main/index.js",
  "author": "YuMatrix",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "start": "electron-vite preview",
    "dev": "node -e \"process.platform==='win32'&&require('child_process').execSync('chcp 65001',{stdio:'ignore'})\" && electron-vite dev -- --remote-debugging-port=9222",
    "dev:playwright": "node test-playwright-executor.js",
    "build": "electron-vite build",
    "pack:main": "npx repomix --ignore \"account_fingerprints/**/*,account_states/**/*,node_modules/**/*,dist/**/*,public/**/*\" --include \"src/main/**/*,src/scripts/**/*\" && node check-size.js",
    "pack:ui": "npx repomix --ignore \"account_fingerprints/**/*,account_states/**/*,node_modules/**/*,dist/**/*,public/**/*,src/renderer/src/assets/**/*\" --include \"src/renderer/src/**/*\" && node check-size.js",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "axios": "^1.7.2",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.6",
    "electron-store": "^11.0.2",
    "extract-zip": "^2.0.1",
    "fingerprint-generator": "^2.1.82",
    "fingerprint-injector": "^2.1.82",
    "fs-extra": "^11.3.5",
    "imapflow": "^1.4.0",
    "localforage": "^1.10.0",
    "lucide-react": "^0.577.0",
    "mailparser": "^3.9.9",
    "nodemailer": "^8.0.10",
    "playwright-core": "^1.45.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "tree-kill": "^1.2.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/typography": "^0.5.19",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.19",
    "vite": "^7.2.6"
  }
}
